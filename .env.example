# Backend API base (Axios). Required for production if UI and API are on different hosts.
# No trailing slash. Example: https://api.example.com
# Leave empty in local dev to use /api on the Vite dev server (see VITE_PROXY_TARGET).
VITE_API_URL=

# Local dev only: where Vite forwards /api when VITE_API_URL is empty.
# Must match your backend listen URL (host + port).
VITE_PROXY_TARGET=http://127.0.0.1:5001
